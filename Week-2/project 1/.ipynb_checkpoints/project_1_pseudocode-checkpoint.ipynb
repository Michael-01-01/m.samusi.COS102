    "START\n",
    "\n",
    "IF cart is empty\n",
    "  DISPLAY \"Cart is empty\"\n",
    "ELSE\n",
    "   INPUT customer details\n",
    "   SELECT shipping method\n",
    "   SELECT payment method\n",
    "   PROCESS payment\n",
    "\n",
    "   IF payment successful\n",
    "        CONFIRM order\n",
    "   ELSE\n",
    "       DISPLAY \"Payment failed\"\n",
    "   END IF\n",
    "END IF\n",
    "\n",
    "END"
   ]
  }
