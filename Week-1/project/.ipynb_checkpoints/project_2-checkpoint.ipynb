   ],
   "source": [
    "p = float(input(\"input principal\"))\n",
    "r = float(input(\"input rate\"))\n",
    "t = float(input(\"input time\"))\n",
    "n = float(input(\"input number of years\"))\n",
    "\n",
    "a = p* (1 + (r/n))**(n/t)\n",
    "ci = a - p\n",
    "print(\"The compound interest is: \",ci)\n",
    "\n",
    "\n"
   ]
