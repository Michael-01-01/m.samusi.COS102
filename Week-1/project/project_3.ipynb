   ],
   "source": [
    "r = float(input(\"Input rate\"))\n",
    "n = float(input(\"Input number of years\"))\n",
    "t = float(input(\"Input time\"))\n",
    "pmt = float(input(\"Input payment amount\"))\n",
    "\n",
    "y = r/n\n",
    "x = (1 + (r/n))**(n*t)\n",
    "a = pmt*(x - 1)/y\n",
    "print(\"The annuity plan is :\",a)\n"
   ]
  },
